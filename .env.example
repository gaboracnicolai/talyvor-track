# Talyvor Track — environment template.
# Copy to .env and fill in. docker compose reads values automatically.

# ─── Core ──────────────────────────────────────────────────
TRACK_DATABASE_URL=postgres://track:changeme@localhost:5432/talyvor_track?sslmode=disable
TRACK_REDIS_URL=redis://localhost:6379
TRACK_PORT=3000
TRACK_LOG_LEVEL=info

# Postgres password used by the bundled docker-compose stack. Pick
# something unique before exposing the stack beyond localhost.
POSTGRES_PASSWORD=changeme

# ─── Talyvor Lens integration (optional but recommended) ──
# When set, Track surfaces per-issue AI cost in the UI and via MCP.
TRACK_LENS_URL=http://localhost:8080
TRACK_LENS_API_KEY=
TRACK_LENS_WEBHOOK_SECRET=

# ─── GitHub integration (optional) ────────────────────────
# Receives PR-merged / PR-opened webhooks at /v1/webhooks/github.
# Sign your webhook secret here and in the repo settings → Webhooks.
TRACK_GITHUB_WEBHOOK_SECRET=
